# ----------------------------------------------------------------------------
# EngPulse AI — environment configuration
# Copy this file to `.env` and fill in the values you need.
# Everything has a sane default except GITHUB_TOKEN / GITHUB_REPO.
# ----------------------------------------------------------------------------

APP_ENV=local
LOG_LEVEL=INFO

# --- Database (matches docker-compose `postgres` service) --------------------
DATABASE_URL=postgresql+psycopg://engpulse:engpulse@localhost:5432/engpulse

# --- GitHub connector --------------------------------------------------------
# Personal Access Token (classic or fine-grained) with `repo` read scope.
# Required for the live read path; leave blank to use only --source fixture.
GITHUB_TOKEN=
# The repo the end-to-end read path targets, as "owner/name".
GITHUB_REPO=your-org/your-repo
GITHUB_API_URL=https://api.github.com

# --- Linear connector (issue tracker) ---------------------------------------
# Personal API key from Linear (Settings > API > Personal API keys).
# Passed directly in the Authorization header. Leave blank to use --source fixture.
LINEAR_API_KEY=
LINEAR_API_URL=https://api.linear.app/graphql
# Optional: scope ingestion to one team by key (e.g. ENG). Empty = all teams.
LINEAR_TEAM_KEY=

# --- Ollama (model-agnostic LLM seam; not called until later modules) --------
# OpenAI-compatible chat endpoint. If Ollama runs on another machine, set
# OLLAMA_HOST=0.0.0.0 there and point this at http://<that-host>:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Redis / Celery (worker + scheduled syncs) ------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Langfuse (self-hosted tracing; wired now, exercised in later modules) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
